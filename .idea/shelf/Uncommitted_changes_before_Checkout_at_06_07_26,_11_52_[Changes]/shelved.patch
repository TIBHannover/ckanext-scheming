+scheming_version: 3
+dataset_type: sample
+about: A reimplementation Sample for CKAN, to witness the relationship between packages
+about_url: https://bioschemas.org/profiles/Dataset/1.0-RELEASE
+
+dataset_fields:
+- field_name: title
+  label: Title
+  preset: title
+  form_placeholder: eg. A descriptive title
+
+- field_name: name
+  label: URL
+  preset: dataset_slug
+  form_placeholder: eg. my-dataset
+
+- field_name: owner_org
+  label: Organization
+  preset: dataset_organization
+
+# Chemistry Metadata included
+- field_name: doi
+  label: DOI
+  form_placeholder: ex. '10:xxx-xxx'
+  form_snippet: text.html   # a DOI based snippet can be added where '10:xxx' becomes a 'required' field.
+
+resource_fields:
+
+- field_name: url
+  label: URL
+  preset: resource_url_upload
+
+- field_name: name
+  label: Name
+  form_placeholder: eg. January 2011 Gold Prices
+
+- field_name: description
+  label: Description
+  form_snippet: markdown.html
+  form_placeholder: Some useful notes about the data
+
+- field_name: format
+  label: Format
+  preset: resource_format_autocomplete
+
+#relationship to datasets
+
+- field_name: related_dataset
+  label: Related dataset
+  preset: related_entity
+  current_entity: molecule
+  current_entity_type: molecule
+  related_entity: package
+  related_entity_type: dataset
+  relation_type: parent_of
+  multiple: true
+  updatable_only: false
+  required: false
